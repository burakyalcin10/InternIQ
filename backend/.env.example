# ============================================
# InternIQ — Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ---- Supabase (Veritabanı) ----
# Şu an kullanılmıyor, ileride migration için hazır
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ---- OpenAI (CrewAI Şirket Analizi) ----
# Kullanıldığı yer: Company Research (CrewAI ajanları)
# Sağlayıcı: OpenAI — https://platform.openai.com/api-keys
# Olmadan: Fallback demo rapor döner
OPENAI_API_KEY=your_openai_key_here

# ---- Google Gemini (CV Analizi) ----
# Kullanıldığı yer: CV Tailorer (PDF analiz)
# Sağlayıcı: Google AI Studio — https://aistudio.google.com/apikey
# Olmadan: Keyword-based fallback analiz döner
GEMINI_API_KEY=your_gemini_key_here

# ---- App Config ----
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
